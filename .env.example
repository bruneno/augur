# Copy to .env (Bun loads it automatically) and fill in the oracle you use.
# Augur reads keys from the environment — they are never hardcoded.

# Anthropic — `aug file.aug --oracle anthropic`
ANTHROPIC_API_KEY=

# OpenAI — `aug file.aug --oracle openai`
OPENAI_API_KEY=

# OpenRouter (OpenAI-compatible) — `aug file.aug --oracle openrouter --model openai/gpt-4o-mini`
OPENROUTER_API_KEY=

# Ollama (local, no key) — override only if not on the default host
# OLLAMA_HOST=http://127.0.0.1:11434
